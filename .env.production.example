# Copy these into Vercel → Project → Settings → Environment Variables
# (Do NOT commit a real .env with secrets to Git)

APP_NAME="General Store"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_run_php_artisan_key_generate_show
APP_DEBUG=false
APP_URL=https://your-project.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Serverless / Vercel: writable cache paths
APP_CONFIG_CACHE=/tmp/config.php
APP_EVENTS_CACHE=/tmp/events.php
APP_PACKAGES_CACHE=/tmp/packages.php
APP_ROUTES_CACHE=/tmp/routes.php
APP_SERVICES_CACHE=/tmp/services.php
VIEW_COMPILED_PATH=/tmp/views

# Cloud MySQL (PlanetScale, Railway, Aiven, etc. — NOT localhost)
DB_CONNECTION=mysql
DB_HOST=YOUR_CLOUD_MYSQL_HOST
DB_PORT=3306
DB_DATABASE=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# database = needs sessions & cache tables migrated on cloud DB
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Vercel pe queue worker nahi chalta — sync simple hai
QUEUE_CONNECTION=sync

# Database cache chahiye ho to migrations run karke; warna array bhi chal sakta hai
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
